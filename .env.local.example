# ── Phase 1 ────────────────────────────────────────────────────────────────

# Get your free Groq API key at https://console.groq.com
GROQ_API_KEY=

# Get your free Resend API key at https://resend.com (free tier: 3,000 emails/month)
RESEND_API_KEY=

# The email address where new client inquiries will be sent
DESIGNER_EMAIL=

# The designer's display name used in email subjects and bodies
DESIGNER_NAME=Patrik Uracs Interior Design

# ── Phase 2 ────────────────────────────────────────────────────────────────

# Anthropic API key for Claude Vision (room photo analysis)
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase project credentials
# Get at https://supabase.com → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Short slug identifying this designer's profile in the designers table
# e.g. "patrik-uracs" — used to fetch the style profile for brief personalisation
NEXT_PUBLIC_DESIGNER_SLUG=

# Secret key to protect the /onboard route (set any long random string)
# Access via /onboard?key=YOUR_SECRET
ONBOARD_SECRET=

# ── Phase 3 ────────────────────────────────────────────────────────────────

# fal.ai API key for AI image generation (~$0.003 per image)
# Get at https://fal.ai → sign up → API Keys → add $5 minimum credit
FAL_API_KEY=

# Your full deployed Vercel URL — used to build results page links and trigger
# the background render job. No trailing slash.
# e.g. https://yourapp.vercel.app
NEXT_PUBLIC_APP_URL=

# Password to protect the /dashboard route (set any string you'll remember)
DASHBOARD_PASSWORD=

# Secret used to authenticate Vercel cron job calls to /api/cron/digest
# Set any long random string (e.g. generate with: openssl rand -hex 32)
# Add this same value in Vercel → Settings → Environment Variables
CRON_SECRET=
